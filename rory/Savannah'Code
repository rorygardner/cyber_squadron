import numpy as np


group_m = monthly.loc[monthly['metro_label'] == 1, 'PC1'].to_numpy(dtype=float)
group_nm = monthly.loc[monthly['metro_label'] == 0, 'PC1'].to_numpy(dtype=float)

np.random.seed(21) # Seed for reproducibility

def permutation_test(group_a, group_b, num_permutations=10000):
    """
    Permutation test for average PC1 scores and calculates the Probability of Superiority (P).

    Args:
        group_a: numpy array-like object with scores for first group.
        group_b: numpy array-like object with scores for second group.
        num_permutations (int): number of permutations.

    Returns:
        tuple: (p_value, common_language_effect_size)
    """
    group_a = np.array(group_a)
    group_b = np.array(group_b)

    n_a = len(group_a)
    combined = np.concatenate((group_a, group_b))
    observed_diff = np.mean(group_a) - np.mean(group_b)

    p_value_count = 0

    # 1. Permutation Test for P-value (Same as your original code)
    for _ in range(num_permutations):
        perm = np.random.permutation(combined)
        perm_diff = np.mean(perm[:n_a]) - np.mean(perm[n_a:])

        if np.abs(perm_diff) >= np.abs(observed_diff):
            p_value_count += 1

    p_value = (p_value_count + 1) / (num_permutations + 1)

    # 2. Calculate the Common Language Effect Size (P)
    # The probability that a random value from group_a is greater than a random value from group_b.
    # This is calculated on the observed, not permuted, data.
    count_superior = 0
    total_comparisons = n_a * len(group_b)

    # Iterate over all possible pairs of observations (x_a, x_b)
    for val_a in group_a:
        for val_b in group_b:
            if val_a > val_b:
                count_superior += 1

    common_language_effect_size = count_superior / total_comparisons

    return p_value, common_language_effect_size

# --- Execution ---


group_m = np.random.normal(loc=10, scale=2, size=50)
group_nm = np.random.normal(loc=12, scale=2, size=60)

p_value, p_effect_size = permutation_test(group_m, group_nm)

# --- Results ---
print(f"Permutation Test P-value: {p_value:.4f}")
print(f"Common Language Effect Size (P): {p_effect_size:.4f}")
