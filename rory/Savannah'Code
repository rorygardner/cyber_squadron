# --- Define the Bootstrap Function ---

def bootstrap_ci(group_a, group_b, num_samples=10000, ci_level=0.95):
    """
    Calculates the two-sample bootstrap confidence interval for the difference in means.

    Args:
        group_a: numpy array-like object with scores for the first group.
        group_b: numpy array-like object with scores for the second group.
        num_samples (int): The number of bootstrap samples to draw.
        ci_level (float): The desired confidence level (e.g., 0.95 for 95%).

    Returns:
        tuple: (lower_bound, upper_bound) of the confidence interval.
    """
    group_a = np.array(group_a)
    group_b = np.array(group_b)
    n_a = len(group_a)
    n_b = len(group_b)

    # 1. Calculate the observed difference (Optional, but good for context)
    observed_diff = np.mean(group_a) - np.mean(group_b)

    # 2. Perform the bootstrap resampling
    diff_of_means = []
    np.random.seed(42) # Set seed for reproducibility

    for _ in range(num_samples):
        # Sample with replacement from each group independently
        sample_a = np.random.choice(group_a, size=n_a, replace=True)
        sample_b = np.random.choice(group_b, size=n_b, replace=True)

        # Calculate the difference in means for the bootstrap sample
        bootstrap_diff = np.mean(sample_a) - np.mean(sample_b)
        diff_of_means.append(bootstrap_diff)

    # 3. Calculate the confidence interval bounds (Percentile Method)
    # The error (alpha) is split between the two tails
    alpha = 1.0 - ci_level
    lower_percentile = alpha / 2 * 100
    upper_percentile = (1.0 - alpha / 2) * 100

    # Find the percentiles of the distribution of differences
    lower_bound = scoreatpercentile(diff_of_means, lower_percentile)
    upper_bound = scoreatpercentile(diff_of_means, upper_percentile)

    print(f"Observed Difference in Means: {observed_diff:.4f}")
    return lower_bound, upper_bound

